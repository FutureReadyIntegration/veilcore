COMMANDS = {
    "status": cmd_status,
    "start": cmd_start,
    "stop": cmd_stop,
    "restart": cmd_restart,
    "logs": cmd_logs,
    "health": cmd_health,
    "patients": cmd_patients,
    "audit": cmd_audit,
    "lockdown": cmd_lockdown,
    "unlock": cmd_unlock,
    "help": cmd_help,
    "--help": cmd_help,
    "-h": cmd_help,
}

def main():
    if len(sys.argv) < 2:
        return cmd_status([])
    
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    if cmd in COMMANDS:
        return COMMANDS[cmd](args)
    else:
        print(f"{RED}Unknown command: {cmd}{NC}")
        print(f"Run 'veilctl help' for usage")
        return 1

if __name__ == "__main__":
    sys.exit(main())
