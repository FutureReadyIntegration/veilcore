#!/usr/bin/env python3
"""
veilctl - The Veil Control CLI
==============================
Manage The Veil hospital cybersecurity platform.

Usage:
    veilctl status              Show status of all organs
    veilctl start [organ]       Start organ(s)
    veilctl stop [organ]        Stop organ(s)
    veilctl restart [organ]     Restart organ(s)
    veilctl logs [organ]        View organ logs
    veilctl health              Health check all organs
    veilctl patients            Patient statistics
    veilctl audit [n]           Show recent audit events
    veilctl lockdown <user>     Emergency lockdown user
    veilctl unlock <user>       Remove lockdown
"""

import subprocess
import sys
import json
import os
from pathlib import Path
from datetime import datetime
from typing import Optional

# Colors
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
CYAN = '\033[0;36m'
NC = '\033[0m'  # No Color
BOLD = '\033[1m'

ORGANS = {
    "veil": {"desc": "Main API", "tier": "P0", "glyph": "🏥"},
    "sentinel": {"desc": "Anomaly Detection", "tier": "P1", "glyph": "👁️"},
    "insider_threat": {"desc": "Insider Threat", "tier": "P1", "glyph": "🕵️"},
    "auto_lockdown": {"desc": "Auto Response", "tier": "P0", "glyph": "🔒"},
    "zero_trust": {"desc": "Zero Trust", "tier": "P1", "glyph": "🔐"},
}

SERVICE_MAP = {
    "veil": "veil.service",
    "sentinel": "veil-sentinel.service",
    "insider_threat": "veil-insider-threat.service",
    "auto_lockdown": "veil-auto-lockdown.service",
    "zero_trust": "veil-zero-trust.service",
}

STATUS_DIR = Path("/var/lib/veil")
LOG_DIR = Path("/var/log/veil")

def run_cmd(cmd: list, capture: bool = True) -> tuple:
    """Run a shell command."""
    try:
        result = subprocess.run(cmd, capture_output=capture, text=True)
        return result.returncode, result.stdout, result.stderr
    except Exception as e:
        return 1, "", str(e)

def is_service_running(service: str) -> bool:
    """Check if systemd service is running."""
    code, out, _ = run_cmd(["systemctl", "is-active", "--quiet", service])
    return code == 0

def get_service_status(service: str) -> dict:
    """Get detailed service status."""
    code, out, _ = run_cmd(["systemctl", "show", service, 
                           "--property=ActiveState,SubState,MainPID,MemoryCurrent"])
    status = {}
    for line in out.strip().split('\n'):
        if '=' in line:
            k, v = line.split('=', 1)
            status[k] = v
    return status

def get_organ_health(organ: str) -> dict:
    """Get organ health from status.json."""
    paths = [
        STATUS_DIR / organ / "status.json",
        STATUS_DIR / "lockdown" / "status.json" if organ == "auto_lockdown" else None,
        STATUS_DIR / "security" / "status.json" if organ == "veil" else None,
    ]
    
    for path in paths:
        if path and path.exists():
            try:
                return json.loads(path.read_text())
            except:
                pass
    return {}

def print_header(title: str):
    print(f"\n{BLUE}{'='*60}{NC}")
    print(f"{BLUE}  {title}{NC}")
    print(f"{BLUE}{'='*60}{NC}\n")

def cmd_status(args):
    """Show status of all organs."""
    print_header("THE VEIL - System Status")
    
    running = 0
    total = len(ORGANS)
    
    for organ, info in ORGANS.items():
        service = SERVICE_MAP.get(organ, f"veil-{organ}.service")
        is_running = is_service_running(service)
        health = get_organ_health(organ)
        
        if is_running:
            running += 1
            status_info = get_service_status(service)
            mem = status_info.get("MemoryCurrent", "0")
            try:
                mem_mb = int(mem) / 1024 / 1024
                mem_str = f"{mem_mb:.1f}MB"
            except:
                mem_str = "?"
            
            healthy = health.get("healthy", True)
            msg = health.get("message", "")
            
            if healthy:
                icon = f"{GREEN}✓{NC}"
            else:
                icon = f"{YELLOW}⚠{NC}"
            
            print(f"  {icon} {info['glyph']} {BOLD}{organ:18}{NC} {GREEN}RUNNING{NC}  {mem_str:>8}  {msg}")
        else:
            print(f"  {RED}✗{NC} {info['glyph']} {BOLD}{organ:18}{NC} {RED}STOPPED{NC}")
    
    print()
    
    # Summary
    if running == total:
        print(f"  {GREEN}All {total} organs running{NC}")
    elif running == 0:
        print(f"  {RED}All organs stopped!{NC}")
    else:
        print(f"  {YELLOW}{running}/{total} organs running{NC}")
    
    print()
    return 0

def cmd_start(args):
    """Start organ(s)."""
    organ = args[0] if args else "all"
    
    if organ == "all":
        services = list(SERVICE_MAP.values())
        print(f"{CYAN}Starting all organs...{NC}")
    else:
        if organ not in SERVICE_MAP:
            print(f"{RED}Unknown organ: {organ}{NC}")
            return 1
        services = [SERVICE_MAP[organ]]
        print(f"{CYAN}Starting {organ}...{NC}")
    
    for service in services:
        code, _, err = run_cmd(["sudo", "systemctl", "start", service])
        if code == 0:
            print(f"  {GREEN}✓{NC} {service}")
        else:
            print(f"  {RED}✗{NC} {service}: {err}")
    
    return 0

