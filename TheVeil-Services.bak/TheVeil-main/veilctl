def cmd_logs(args):
    """View organ logs."""
    organ = args[0] if args else "veil"
    lines = args[1] if len(args) > 1 else "50"
    
    if organ not in SERVICE_MAP:
        print(f"{RED}Unknown organ: {organ}{NC}")
        return 1
    
    service = SERVICE_MAP[organ]
    print(f"{CYAN}Logs for {organ} (last {lines} lines):{NC}\n")
    
    code, out, err = run_cmd(["journalctl", "-u", service, "-n", lines, "--no-pager"], capture=True)
    if out:
        print(out)
    if err:
        print(err)
    
    return code

def cmd_health(args):
    """Health check all organs."""
    print_header("Health Check")
    
    all_healthy = True
    
    for organ, info in ORGANS.items():
        service = SERVICE_MAP.get(organ)
        running = is_service_running(service)
        health = get_organ_health(organ)
        
        checks = []
        
        # Service running
        if running:
            checks.append(f"{GREEN}✓ Service running{NC}")
        else:
            checks.append(f"{RED}✗ Service stopped{NC}")
            all_healthy = False
        
        # Health status
        if health.get("healthy"):
            checks.append(f"{GREEN}✓ Healthy{NC}")
        elif health:
            checks.append(f"{YELLOW}⚠ Degraded{NC}")
            all_healthy = False
        
        # Stale check
        if health.get("stale"):
            checks.append(f"{YELLOW}⚠ Stale status{NC}")
        
        print(f"  {info['glyph']} {BOLD}{organ}{NC}")
        for check in checks:
            print(f"      {check}")
        print()
    
    if all_healthy:
        print(f"  {GREEN}All systems healthy{NC}")
    else:
        print(f"  {YELLOW}Some issues detected{NC}")
    
    return 0 if all_healthy else 1

def cmd_patients(args):
    """Show patient statistics."""
    print_header("Patient Statistics")
    
    try:
        patients_file = Path("/var/lib/veil/patients.json")
        if not patients_file.exists():
            patients_file = Path("/opt/veil_os/veil/hospital_gui/data/patients.json")
        
        if patients_file.exists():
            data = json.loads(patients_file.read_text())
            patients = data.get("patients", [])
            
            active = [p for p in patients if not p.get("discharged_at")]
            discharged = [p for p in patients if p.get("discharged_at")]
            
            print(f"  Total patients:      {len(patients)}")
            print(f"  {GREEN}Active:              {len(active)}{NC}")
            print(f"  {BLUE}Discharged:          {len(discharged)}{NC}")
        else:
            print(f"  {YELLOW}No patient data found{NC}")
    except Exception as e:
        print(f"  {RED}Error reading patients: {e}{NC}")
    
    print()
    return 0

def cmd_audit(args):
    """Show recent audit events."""
    n = int(args[0]) if args else 20
    print_header(f"Recent Audit Events (last {n})")
    
    audit_file = Path("/var/lib/veil/audit/audit.log")
    if not audit_file.exists():
        print(f"  {YELLOW}No audit log found{NC}")
        return 0
    
    try:
        lines = audit_file.read_text().strip().split('\n')
        recent = lines[-n:] if len(lines) > n else lines
        
        for line in recent:
            try:
                event = json.loads(line)
                ts = event.get("timestamp", "")[:19]
                level = event.get("level", "INFO")
                action = event.get("action", "")
                user = event.get("username", "-")
                
                if level == "ERROR":
                    color = RED
                elif level == "WARNING":
                    color = YELLOW
                else:
                    color = NC
                
                print(f"  {ts}  {color}{level:8}{NC}  {user:12}  {action}")
            except:
                print(f"  {line[:80]}")
        
    except Exception as e:
        print(f"  {RED}Error reading audit: {e}{NC}")
    
    print()
    return 0

def cmd_lockdown(args):
    """Emergency lockdown a user."""
    if not args:
        print(f"{RED}Usage: veilctl lockdown <user_id>{NC}")
        return 1
    
    user_id = args[0]
    print(f"{RED}EMERGENCY LOCKDOWN: {user_id}{NC}")
    
    # Call API
    import urllib.request
    import urllib.error
    
    try:
        data = json.dumps({
            "target_type": "user",
            "target_id": user_id,
            "level": "lockdown",
            "reason": "Emergency lockdown via veilctl"
        }).encode()
        
        req = urllib.request.Request(
            "http://localhost:8000/api/security/lockdown",
            data=data,
            headers={"Content-Type": "application/json"}
        )
        
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())
            print(f"  {GREEN}✓ User {user_id} locked down{NC}")
            return 0
            
    except urllib.error.HTTPError as e:
        print(f"  {RED}✗ API error: {e.code}{NC}")
        return 1
    except Exception as e:
        print(f"  {RED}✗ Error: {e}{NC}")
        return 1

def cmd_unlock(args):
    """Remove lockdown from user."""
    if not args:
        print(f"{RED}Usage: veilctl unlock <user_id>{NC}")
        return 1
    
    user_id = args[0]
    print(f"{CYAN}Removing lockdown: {user_id}{NC}")
    
    import urllib.request
    import urllib.error
    
    try:
        data = json.dumps({
            "target_type": "user",
            "target_id": user_id,
            "reason": "Manual unlock via veilctl"
        }).encode()
        
        req = urllib.request.Request(
            "http://localhost:8000/api/security/unlock",
            data=data,
            headers={"Content-Type": "application/json"}
        )
        
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())
            print(f"  {GREEN}✓ Lockdown removed{NC}")
            return 0
            
    except Exception as e:
        print(f"  {RED}✗ Error: {e}{NC}")
        return 1

