"""
Veil Hospital GUI main application
Full prototype entrypoint exposing /api/status, /api/organs and /health.
"""
from __future__ import annotations
import secrets
import threading
from pathlib import Path
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse, HTMLResponse
from fastapi.staticfiles import StaticFiles
# runtime context provided by the Veil runtime package
from veil.runtime.context import telemetry, security

BASE_DIR = Path(__file__).parent
STATIC_DIR = BASE_DIR / "static"

app = FastAPI(title="Veil Hospital GUI", version="prototype-1.0")

# serve static assets if present
if STATIC_DIR.exists() and STATIC_DIR.is_dir():
    app.mount("/static", StaticFiles(directory=str(STATIC_DIR)), name="static")

@app.on_event("startup")
async def on_startup():
    # start host sensor in a daemon thread so it doesn't block startup
    from organs.host_sensor import Organ as HostSensor
    sensor = HostSensor(None, telemetry, security)
    t = threading.Thread(target=sensor.start, daemon=True, name="veil-host-sensor")
    t.start()

@app.middleware("http")
async def add_request_id(request: Request, call_next):
    response = await call_next(request)
    response.headers["X-Request-ID"] = secrets.token_hex(8)
    return response

@app.get("/", response_class=HTMLResponse)
async def root():
    """Serve the main dashboard HTML"""
    index_file = STATIC_DIR / "index.html"
    if index_file.exists():
        return HTMLResponse(content=index_file.read_text(), status_code=200)
    return JSONResponse({"error": "Dashboard not found"}, status_code=404)

@app.get("/api/status", response_class=JSONResponse)
async def api_status():
    """
    Returns latest CPU and memory metrics, lockdown state, and security event count.
    Defensive access to telemetry and security to avoid runtime errors.
    """
    cpu = 0
    mem = 0
    try:
        metrics = getattr(telemetry, "metrics", [])
        if metrics:
            # metrics appended as cpu, memory pairs; pick last two values defensively
            if len(metrics) >= 2:
                cpu = metrics[-2].get("value", 0)
                mem = metrics[-1].get("value", 0)
            else:
                cpu = metrics[-1].get("value", 0)
    except Exception:
        cpu = 0
        mem = 0
    
    lockdown = getattr(security, "lockdown", False)
    events = getattr(security, "events", [])
    event_count = len(events) if isinstance(events, list) else 0
    
    return {"cpu": cpu, "memory": mem, "lockdown": lockdown, "security_events": event_count}

@app.get("/api/organs", response_class=JSONResponse)
async def api_organs():
    """Return status of all security organs"""
    # TODO: Replace with actual organ discovery/status checking
    organs = [
        {"name": "Guardian", "status": "running", "priority": "P0"},
        {"name": "Sentinel", "status": "running", "priority": "P0"},
        {"name": "Audit", "status": "stopped", "priority": "P0"},
        {"name": "Behavioral Anomaly Detection", "status": "stopped", "priority": "P1"},
        {"name": "Host Sensor", "status": "running", "priority": "P1"},
    ]
    return {"organs": organs, "total": len(organs), "running": sum(1 for o in organs if o["status"] == "running")}

@app.get("/health")
async def health():
    return {"status": "healthy"}

def main():
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)

if __name__ == "__main__":
    main()
