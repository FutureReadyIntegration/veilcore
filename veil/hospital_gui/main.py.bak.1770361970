    return {"patients": data.get("patients", []), "total": len(data.get("patients", []))}

@app.post("/api/patients", status_code=status.HTTP_201_CREATED)
def api_create_patient(payload: dict):
    data = _load_patients()
    next_id = data.get("next_id", 1)
    patient = {"id": next_id, "name": payload.get("name"), "dob": payload.get("dob")}
    data.setdefault("patients", []).append(patient)
