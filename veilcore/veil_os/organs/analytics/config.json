{ "name": "analytics", "enabled": true, "description": "Analytics organ for telemetry aggregation, anomaly detection, and alerting.", "storage": { "type": "filesystem", "path": "/var/lib/veil/analytics", "retention_days": 90, "max_size_mb": 10240 }, "ingest": { "sources": [ { "name": "syslog", "type": "file", "path": "/var/log/syslog", "parser": "syslog" }, { "name": "veil_events", "type": "unix_socket", "socket_path": "/var/run/veil/events.sock" } ], "batch_interval_seconds": 60, "max_batch_size": 1000 }, "analysis": { "window_hours": 24, "sampling_rate": 1.0, "anomaly_detection": { "enabled": true, "method": "z_score", "z_threshold": 3.5 }, "aggregation": { "granularity_seconds": 300, "metrics": ["count", "unique_users", "avg_latency"] } }, "alerting": { "enabled": true, "risk_threshold": 80, "escalation": [ { "level": "warning", "threshold": 60, "actions": ["log", "webhook"] }, { "level": "critical", "threshold": 90, "actions": ["log", "webhook", "email"] } ], "webhook": { "url": "<your-webhook-url>", "timeout_seconds": 5, "retries": 3, "backoff_seconds": 10 }, "email": { "from": "veil-alerts@example.local", "to": ["secops@example.local"], "smtp": { "host": "smtp.example.local", "port": 587, "use_tls": true, "username": "<smtp-user>", "password": "<smtp-password>" } } }, "logging": { "level": "INFO", "file": "/var/log/veil/analytics.log", "rotate": { "enabled": true, "max_size_mb": 100, "max_files": 7 } }, "performance": { "worker_threads": 2, "max_memory_mb": 512, "cpu_affinity": null }, "security": { "run_as_user": "veil", "file_permissions": { "config_mode": "0640", "dir_mode": "0750" } }, "maintenance": { "auto_compact": true, "compact_interval_hours": 24, "backup_enabled": false, "backup_path": "/var/backups/veil/analytics" } }
